#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    float p,r,t;
    scanf("%f",&p);
    scanf("%f",&r);
    scanf("%f",&t);
    float i = (p * r * t)/100;
    float a = p + i;
    float  d = (2*i)/100;
    float f = a - d;
    printf("%.2f\n",i);
    printf("%.2f\n",a);
    printf("%.2f\n",d);
    printf("%.2f\n",f);
    
    return 0;
}
