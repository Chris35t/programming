var grade = prompt("Enter your grade ")
grade = parseFloat(grade)
if(grade >= 90){
    console.log("A grade")
}else if (grade >= 80){
    console.log("B grade")
}else if(grade >= 70){
    console.log("C grade")
}else if(grade >= 60){
    console.log("D grade");
}else{
    console.log("you got an F")
}
